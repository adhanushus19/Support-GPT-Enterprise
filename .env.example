# SupportGPT Enterprise environment variables configuration

# API Server Config
APP_NAME=SupportGPT-Enterprise
APP_ENV=development
DEBUG=true
PORT=8000
HOST=0.0.0.0

# Security and Auth
JWT_SECRET=super-secret-jwt-key-change-in-production-123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database & Cache
# For testing and dev without local Postgres:
# sqlite+aiosqlite:///./supportgpt.db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/supportgpt
REDIS_URL=redis://localhost:6379/0

# LLM Providers (mock, openai, azure)
LLM_PROVIDER=mock
OPENAI_API_KEY=your-openai-api-key-here
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4

# Vector DB
VECTOR_DB_PERSIST_DIR=./chromadb_store
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Observability
PROMETHEUS_METRICS_ENABLED=true
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=supportgpt-enterprise

# Guardrails Settings
PII_ANONYMIZATION_ENABLED=true
PROMPT_INJECTION_PROTECTION_ENABLED=true
JAILBREAK_DETECTION_ENABLED=true
RESPONSE_FILTERING_ENABLED=true
